# ─── Supabase (somente backend) ───────────────────────────────────────────────
SUPABASE_URL=https://supabase.flexofertas.shop/
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL do frontend hospedado na Hostinger
CORS_ORIGIN=https://royalhubacademy.com

# ─── Cookies ──────────────────────────────────────────────────────────────────
# Domínio para cookies cross-domain (ex: frontend em royalhubacademy.com, backend em api.royalhubacademy.com)
COOKIE_DOMAIN=.royalhubacademy.com

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
