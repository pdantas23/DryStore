{
  "include": ["server/**/*"],
  "exclude": ["client", "node_modules", "dist"],
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "outDir": "dist",        
    "rootDir": ".",          
    "types": ["node"],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  }
}